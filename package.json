{
  "name": "eduscope",
  "productName": "Eduscope",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron release server.js",
    "lint": "tsc --noEmit",
    "electron:compile": "esbuild electron/main.ts --bundle --platform=node --packages=external --outdir=dist-electron --format=cjs --out-extension:.js=.cjs && esbuild electron/preload.ts --bundle --platform=node --packages=external --outdir=dist-electron --format=cjs --out-extension:.js=.cjs",
    "electron:dev": "npm run electron:compile && concurrently --kill-others -n VITE,ELECTRON -c blue,green \"tsx server.ts\" \"wait-on http://localhost:3005 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "vite build && npm run electron:compile && electron-builder",
    "electron:preview": "vite build && npm run electron:compile && cross-env NODE_ENV=production electron ."
  },
  "build": {
    "appId": "com.dsden13.eduscope",
    "productName": "Eduscope",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "imapflow": "^1.4.0",
    "lucide-react": "^0.546.0",
    "mailparser": "^3.9.9",
    "motion": "^12.23.24",
    "node-fetch": "^2.7.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  }
}
